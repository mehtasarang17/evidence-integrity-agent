# AWS Bedrock
AWS_BEARER_TOKEN_BEDROCK=your-bearer-token-here
AWS_DEFAULT_REGION=ap-south-1
BEDROCK_MODEL=apac.amazon.nova-lite-v1:0
EMBEDDING_MODEL=amazon.titan-embed-text-v2:0

# Cloud Compliance Providers
COMPLIANCE_AWS_ACCESS_KEY=
COMPLIANCE_AWS_SECRET_KEY=
COMPLIANCE_AWS_REGION=ap-south-1
COMPLIANCE_AWS_ACCOUNT_ID=
COMPLIANCE_AWS_IAM_USERNAME=
COMPLIANCE_AWS_IAM_PASSWORD=

COMPLIANCE_AZURE_ACCESS_TOKEN=
COMPLIANCE_AZURE_TENANT_ID=
COMPLIANCE_AZURE_CLIENT_ID=
COMPLIANCE_AZURE_CLIENT_SECRET=

COMPLIANCE_GITHUB_TOKEN=



# LangSmith (optional - for tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=evidence-integrity-agent

# PostgreSQL
POSTGRES_USER=evidence_user
POSTGRES_PASSWORD=evidence_secure_pass_2024
POSTGRES_DB=evidence_integrity
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://evidence_user:evidence_secure_pass_2024@postgres:5432/evidence_integrity

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production
MAX_UPLOAD_SIZE_MB=50
